[user]
	name = Suggon
	email = maharjansagun99@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[gpg]
	format = ssh
[commit]
	gpgsign = true

# for easier auth, always use SSH url when cloning and adding origin
[url "git@github.com:"]
	insteadOf = https://github.com/
